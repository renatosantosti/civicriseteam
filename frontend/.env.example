# RAG chat: server function + RAG; single API key for either provider. Do not use VITE_ prefix so the key stays server-side.
RAG_LLM_PROVIDER=anthropic
RAG_LLM_API_KEY=your-api-key-here
# Optional: override default model (e.g. gpt-4o, claude-sonnet-4-5-20250929)
# RAG_LLM_MODEL=

# Backend API base URL for auth, signup, user management, etc. (chat does not use the backend.)
VITE_API_URL=http://localhost:8000

# Convex configuration
VITE_CONVEX_URL=your-convex-deployment-url-here

# Sentry configuration
VITE_SENTRY_DSN=your-sentry-dsn-here
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# Netlify-native RAG (used by Netlify Functions: crawl-city-sources, retrieve-context, rag-index-status)
# NETLIFY_RAG_SOURCE_URLS=https://www.montgomeryal.gov/,https://www.montgomeryal.gov/services
# NETLIFY_RAG_STORE=civic-rag
# NETLIFY_RAG_TOP_K=5
# For local dev only: Blobs needs siteID and token when not running on Netlify (see plan "Configuração no Netlify").
# NETLIFY_SITE_ID=your-netlify-site-id
# NETLIFY_AUTH_TOKEN=your-netlify-personal-access-token

# Important! Never commit your `.env` file to version control as it contains sensitive information.