# LLM Configuration
LLM_PROVIDER=openai
LLM_API_KEY=xx
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7

# App
APP_NAME=Civic Copilot API

# Auth: same secret as Convex JWT_SECRET (used to verify tokens issued by Convex signIn)
JWT_SECRET=your-jwt-secret-here

# CORS: comma-separated list of allowed origins (e.g. https://your-app.netlify.app). localhost:3000 is always allowed.
# CORS_ORIGINS=https://fancy-torte-de5b85.netlify.app
